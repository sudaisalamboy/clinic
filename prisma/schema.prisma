// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// The single owner of this app. Only one row will ever exist.
model Owner {
  id              String    @id @default(cuid())
  name            String
  passwordHash    String
  passwordSalt    String
  /// Auto-lock timeout in minutes (used by the client & server cookie maxAge).
  autoLockMinutes Int       @default(15)
  /// Counter for consecutive failed login attempts.
  failedAttempts  Int       @default(0)
  /// If set, login is blocked until this time.
  lockedUntil     DateTime?
  /// Hint shown on the lock screen (optional).
  passwordHint    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sessions        Session[]
}

/// Active sessions for the owner. Single user, but supports multiple devices.
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  ownerId   String
  owner     Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([ownerId])
}

/// Owner's private notes.
model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Owner's private bookmarks/links.
model Link {
  id        String   @id @default(cuid())
  title     String
  url       String
  category  String?
  createdAt DateTime @default(now())
}

/// Audit log of important owner actions.
model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  detail    String?
  ip        String?
  createdAt DateTime @default(now())
}

// ---------- Clinic domain models ----------

model Patient {
  id          String    @id @default(cuid())
  /// Auto-generated human-readable code, e.g. PAT-2026-0001
  patientCode String    @unique
  name        String
  /// Stored date of birth. Age is computed live in the UI from this.
  dateOfBirth DateTime?
  gender      String?
  phone       String?
  email       String?
  address     String?
  bloodGroup  String?
  notes       String?
  /// Active | Inactive. DELETE soft-deletes by setting this to Inactive.
  status      String    @default("Active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  appointments Appointment[]
  bills        Bill[]
  medicalRecords MedicalRecord[]
  prescriptions Prescription[]

  @@index([status])
  @@index([name])
}

model Appointment {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  /// Optional link to the doctor handling this appointment.
  doctorId    String?
  doctor      Doctor?  @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  scheduledAt DateTime
  reason      String?
  /// Scheduled | Confirmed | Checked-In | Completed | Cancelled | No Show
  status      String   @default("Scheduled")
  fee         Float    @default(0)
  /// Daily token number, e.g. A-001, A-002... resets each day per doctor.
  tokenNumber String?
  /// Whether a reminder has been shown to the owner.
  reminderSent Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bill Bill?

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@index([status])
  @@index([tokenNumber])
}

model Bill {
  id              String   @id @default(cuid())
  /// Auto-generated like BILL-2026-0001
  billNumber      String   @unique
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId   String?  @unique
  appointment     Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  doctorId        String?
  doctor          Doctor?  @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  /// JSON string of line items: [{category: 'medicine'|'lab'|'other', name, qty, price}]
  items           String   @default("[]")
  /// Doctor consultation fee (separate line for clarity)
  consultationFee Float    @default(0)
  /// Sum of medicine items
  medicineCharges Float    @default(0)
  /// Sum of lab items
  labCharges      Float    @default(0)
  /// Sum of other items
  otherCharges    Float    @default(0)
  /// Subtotal before discount and tax
  subtotal        Float    @default(0)
  /// Discount amount (computed from discountValue + discountType)
  discountAmount  Float    @default(0)
  /// "percent" | "fixed"
  discountType    String   @default("fixed")
  /// The raw discount value (e.g. 10 for 10% or $10)
  discountValue   Float    @default(0)
  /// Tax amount (computed from taxRate)
  taxAmount       Float    @default(0)
  /// Tax rate in percent (e.g. 8.5)
  taxRate         Float    @default(0)
  /// Final total after discount + tax
  total           Float    @default(0)
  /// Amount paid so far (sum of successful payments)
  amountPaid      Float    @default(0)
  /// Pending | Partial | Paid | Refunded
  status          String   @default("Pending")
  /// Default payment method for the bill
  paymentMethod   String?  // Cash | Card | Online
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  payments Payment[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@index([createdAt])
}

/// Individual payment records for a bill (supports partial payments + refunds).
model Payment {
  id        String   @id @default(cuid())
  billId    String
  bill      Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  amount    Float
  /// Cash | Card | Online
  method    String   @default("Cash")
  /// payment | refund
  type      String   @default("payment")
  note      String?
  createdAt DateTime @default(now())

  @@index([billId])
  @@index([createdAt])
}

model Medicine {
  id            String    @id @default(cuid())
  name          String
  /// Brand name on the package, e.g. "Tylenol"
  genericName   String?
  sku           String?   @unique
  manufacturer  String?
  /// Batch number for traceability
  batchNumber   String?
  /// Stock on hand
  quantity      Int       @default(0)
  /// Selling price per unit
  price         Float     @default(0)
  /// Purchase (cost) price per unit
  purchasePrice Float     @default(0)
  /// Threshold below which a reorder alert fires
  reorderLevel  Int       @default(10)
  /// Expiry date of the current batch
  expiryDate    DateTime?
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([name])
  @@index([manufacturer])
  @@index([expiryDate])
  @@index([quantity])
}

// ---------- Prescription & Medical Record ----------

/// A medical record captures the clinical encounter: vitals, diagnosis, symptoms,
/// examination notes. A prescription is generated from a medical record.
model MedicalRecord {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId     String?
  doctor       Doctor?  @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  appointmentId String?
  /// Visit date / encounter date
  visitDate    DateTime @default(now())
  /// Chief complaint, e.g. "Fever for 3 days"
  symptoms     String?
  /// Vitals
  temperature  String?
  bloodPressure String?
  pulse        String?
  weight       String?
  height       String?
  /// Diagnosis
  diagnosis    String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  prescription Prescription?

  @@index([patientId])
  @@index([doctorId])
}

model Prescription {
  id              String   @id @default(cuid())
  /// Auto-generated like RX-2026-0001
  prescriptionNumber String @unique
  medicalRecordId String   @unique
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId        String?
  doctor          Doctor?  @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  /// JSON array of prescribed medicines: [{medicineId, name, dosage, frequency, duration, instructions}]
  medicines       String   @default("[]")
  /// General advice / special instructions
  advice          String?
  /// Optional follow-up / next visit date
  nextVisitDate   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([createdAt])
}

// ---------- Doctor & Department ----------

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  doctors     Doctor[]
}

model Doctor {
  id              String   @id @default(cuid())
  /// Auto-generated like DOC-2026-0001
  doctorCode      String   @unique
  name            String
  /// specialty / qualification, e.g. "Cardiologist, MD"
  specialization  String?
  phone           String?
  email           String?
  /// consultation fee in USD
  consultationFee Float    @default(0)
  /// Active | Inactive
  status          String   @default("Active")
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  schedule     DoctorSchedule[]
  appointments Appointment[]
  bills        Bill[]
  medicalRecords MedicalRecord[]
  prescriptions Prescription[]

  @@index([status])
  @@index([departmentId])
}

/// One row per working day for a doctor. Days: 0=Sun ... 6=Sat.
model DoctorSchedule {
  id        String   @id @default(cuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  /// 0 (Sun) - 6 (Sat)
  dayOfWeek Int
  /// "09:00" — 24h local time
  startTime String
  /// "17:00"
  endTime   String
  /// if false, doctor is off that day (we still keep the row)
  isWorking Boolean  @default(true)

  @@unique([doctorId, dayOfWeek])
  @@index([doctorId])
}


