// Prisma schema for Clinic Management System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- Auth ----------

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  passwordHash String
  passwordSalt String
  role      String   @default("Admin") // Admin | Receptionist
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions  Session[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@index([userId])
}

model Settings {
  id          String   @id @default(cuid())
  clinicName  String   @default("My Clinic")
  logo        String?
  doctorName  String?
  mobile      String?
  email       String?
  address     String?
  gstNumber   String?
  currency    String   @default("₹")
  timezone    String   @default("Asia/Kolkata")
  primaryColor String  @default("#10b981")
  accentColor  String  @default("#0d9488")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------- Staff ----------

model Staff {
  id          String   @id @default(cuid())
  name        String
  gender      String?
  mobile      String?
  email       String?
  address     String?
  photo       String?
  role        String   @default("Staff") // Doctor, Nurse, Receptionist, Staff
  department  String?
  salary      Float    @default(0)
  joiningDate DateTime @default(now())
  status      String   @default("Active") // Active | Inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  appointments Appointment[]
  @@index([role])
  @@index([status])
}

// ---------- Suppliers ----------

model Supplier {
  id          String   @id @default(cuid())
  name        String
  mobile      String?
  email       String?
  address     String?
  photo       String?
  supplies    String?  // what they supply
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       InventoryItem[]
  @@index([name])
}

// ---------- Inventory ----------

model InventoryCategory {
  id    String @id @default(cuid())
  name  String @unique
  order Int    @default(0)
  items InventoryItem[]
}

model InventoryItem {
  id            String   @id @default(cuid())
  name          String
  categoryId    String
  category      InventoryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  batchNumber   String?
  expiryDate    DateTime?
  unit          String?  // e.g. "box", "strip", "piece"
  quantity      Int      @default(0)
  minStock      Int      @default(10)
  purchasePrice Float    @default(0)
  sellingPrice  Float    @default(0)
  mrp           Float    @default(0)
  gst           Float    @default(0) // percent
  status        String   @default("Active") // Active | Inactive
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  transactions  StockTransaction[]
  billItems     BillItem[]
  @@index([categoryId])
  @@index([supplierId])
  @@index([name])
}

model StockTransaction {
  id        String   @id @default(cuid())
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type      String   // "in" | "out"
  quantity  Int
  note      String?
  createdAt DateTime @default(now())
  @@index([itemId])
  @@index([createdAt])
}

// ---------- Consultation Fees ----------

model ConsultationFee {
  id          String  @id @default(cuid())
  name        String  // General OPD, Follow Up, Emergency
  fee         Float   @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  appointments Appointment[]
}

// ---------- Appointments ----------

model Appointment {
  id              String   @id @default(cuid())
  patientName     String
  mobile          String?
  staffId         String?  // doctor
  staff           Staff?   @relation(fields: [staffId], references: [id], onDelete: SetNull)
  consultationFeeId String?
  consultationFee ConsultationFee? @relation(fields: [consultationFeeId], references: [id], onDelete: SetNull)
  date            DateTime
  type            String   @default("Walk-in") // Walk-in | Website | Phone
  fee             Float    @default(0)
  status          String   @default("Pending") // Pending | Completed | Cancelled | No Show
  notes           String?
  bill            Bill?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([date])
  @@index([status])
  @@index([staffId])
}

// ---------- Billing ----------

model Bill {
  id               String   @id @default(cuid())
  billNumber       String   @unique
  appointmentId    String?  @unique
  appointment      Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  patientName      String
  mobile           String?
  consultationCharge Float  @default(0)
  medicineCharge   Float    @default(0)
  discount         Float    @default(0)
  discountType     String   @default("fixed") // fixed | percent
  gst              Float    @default(0) // percent
  grandTotal       Float    @default(0)
  paymentMethod    String   @default("Cash") // Cash | UPI | Card | Bank Transfer
  paymentStatus    String   @default("Pending") // Pending | Paid
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  items            BillItem[]
  @@index([createdAt])
  @@index([paymentStatus])
}

model BillItem {
  id        String @id @default(cuid())
  billId    String
  bill      Bill   @relation(fields: [billId], references: [id], onDelete: Cascade)
  itemId    String?
  item      InventoryItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)
  name      String
  qty       Int    @default(1)
  price     Float  @default(0)
  @@index([billId])
}
