// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// The single owner of this app. Only one row will ever exist.
model Owner {
  id              String    @id @default(cuid())
  name            String
  passwordHash    String
  passwordSalt    String
  /// Auto-lock timeout in minutes (used by the client & server cookie maxAge).
  autoLockMinutes Int       @default(15)
  /// Counter for consecutive failed login attempts.
  failedAttempts  Int       @default(0)
  /// If set, login is blocked until this time.
  lockedUntil     DateTime?
  /// Hint shown on the lock screen (optional).
  passwordHint    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sessions        Session[]
}

/// Active sessions for the owner. Single user, but supports multiple devices.
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  ownerId   String
  owner     Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([ownerId])
}

/// Owner's private notes.
model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Owner's private bookmarks/links.
model Link {
  id        String   @id @default(cuid())
  title     String
  url       String
  category  String?
  createdAt DateTime @default(now())
}

/// Audit log of important owner actions.
model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  detail    String?
  ip        String?
  createdAt DateTime @default(now())
}

// ---------- Clinic domain models ----------

model Patient {
  id          String    @id @default(cuid())
  /// Auto-generated human-readable code, e.g. PAT-2026-0001
  patientCode String    @unique
  name        String
  /// Stored date of birth. Age is computed live in the UI from this.
  dateOfBirth DateTime?
  gender      String?
  phone       String?
  email       String?
  address     String?
  bloodGroup  String?
  notes       String?
  /// Active | Inactive. DELETE soft-deletes by setting this to Inactive.
  status      String    @default("Active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  appointments Appointment[]
  bills        Bill[]

  @@index([status])
  @@index([name])
}

model Appointment {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  /// Optional link to the doctor handling this appointment.
  doctorId    String?
  doctor      Doctor?  @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  scheduledAt DateTime
  reason      String?
  /// Scheduled | Confirmed | Checked-In | Completed | Cancelled | No Show
  status      String   @default("Scheduled")
  fee         Float    @default(0)
  /// Daily token number, e.g. A-001, A-002... resets each day per doctor.
  tokenNumber String?
  /// Whether a reminder has been shown to the owner.
  reminderSent Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bill Bill?

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@index([status])
  @@index([tokenNumber])
}

model Bill {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointmentId String?  @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  items         String   // JSON string of {name, qty, price}[]
  total         Float
  status        String   @default("pending") // pending | paid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([patientId])
}

model Medicine {
  id           String   @id @default(cuid())
  name         String
  sku          String?  @unique
  quantity     Int      @default(0)
  price        Float    @default(0)
  reorderLevel Int      @default(10)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------- Doctor & Department ----------

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  doctors     Doctor[]
}

model Doctor {
  id              String   @id @default(cuid())
  /// Auto-generated like DOC-2026-0001
  doctorCode      String   @unique
  name            String
  /// specialty / qualification, e.g. "Cardiologist, MD"
  specialization  String?
  phone           String?
  email           String?
  /// consultation fee in USD
  consultationFee Float    @default(0)
  /// Active | Inactive
  status          String   @default("Active")
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  schedule     DoctorSchedule[]
  appointments Appointment[]

  @@index([status])
  @@index([departmentId])
}

/// One row per working day for a doctor. Days: 0=Sun ... 6=Sat.
model DoctorSchedule {
  id        String   @id @default(cuid())
  doctorId  String
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  /// 0 (Sun) - 6 (Sat)
  dayOfWeek Int
  /// "09:00" — 24h local time
  startTime String
  /// "17:00"
  endTime   String
  /// if false, doctor is off that day (we still keep the row)
  isWorking Boolean  @default(true)

  @@unique([doctorId, dayOfWeek])
  @@index([doctorId])
}


